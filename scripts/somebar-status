#!/bin/sh

INTERVAL=2

block_cpu() {
    read -r _ c1 c2 c3 c4 rest < /proc/stat
    total1=$((c1 + c2 + c3 + c4))
    idle1=$c4
    sleep "$INTERVAL"
    read -r _ c1 c2 c3 c4 rest < /proc/stat
    total2=$((c1 + c2 + c3 + c4))
    idle2=$c4
    total=$((total2 - total1))
    idle=$((idle2 - idle1))
    usage=$(( (total - idle) * 100 / total ))
    echo "cpu ${usage}%"
}

block_mem() {
    total=$(awk '/^MemTotal/ { print $2 }' /proc/meminfo)
    avail=$(awk '/^MemAvailable/ { print $2 }' /proc/meminfo)
    used=$(( (total - avail) * 100 / total ))
    echo "mem ${used}%"
}

block_battery() {
    bat=/sys/class/power_supply/BAT0
    cap=$(cat "$bat/capacity")
    status=$(cat "$bat/status")
    case "$status" in
        Charging)    icon="+" ;;
        Discharging) icon="-" ;;
        Full)        icon="=" ;;
        *)           icon="?" ;;
    esac
    echo "bat ${icon}${cap}%"
}

block_net() {
    iface=$(ip route get 1.1.1.1 2>/dev/null | awk '{print $5; exit}')
    [ -z "$iface" ] && echo "no network" && return
    rx1=$(awk -v iface="$iface:" '$1==iface {print $2}' /proc/net/dev)
    sleep "$INTERVAL"
    rx2=$(awk -v iface="$iface:" '$1==iface {print $2}' /proc/net/dev)
    bps=$(( (rx2 - rx1) / INTERVAL ))
    if [ "$bps" -gt 1048576 ]; then
        speed="$(( bps / 1048576 ))MB/s"
    elif [ "$bps" -gt 1024 ]; then
        speed="$(( bps / 1024 ))KB/s"
    else
        speed="${bps}B/s"
    fi
    echo "net $speed"
}

block_volume() {
    vol=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null)
    muted=$(echo "$vol" | grep -c MUTED)
    pct=$(echo "$vol" | awk '{printf "%d", $2 * 100}')
    [ "$muted" -gt 0 ] && echo "vol MUTE" || echo "vol ${pct}%"
}

block_media() {
    status=$(playerctl status 2>/dev/null)
    [ -z "$status" ] && return
    artist=$(playerctl metadata artist 2>/dev/null)
    title=$(playerctl metadata title 2>/dev/null)
    case "$status" in
        Playing) icon=">" ;;
        Paused)  icon="||" ;;
        *)       return ;;
    esac
    echo "$icon $artist - $title"
}

block_recorder() {
    pgrep -x wf-recorder > /dev/null && echo "[REC]" || echo ""
}

block_lang() {
    [ -f /tmp/dwl-keyboard-layout ] && tr -d '\n' < /tmp/dwl-keyboard-layout || echo "us"
}

block_clock() {
    date "+%I:%M %p - %a, %d %b %Y"
}

while true; do
    cpu=$(block_cpu) &
    net=$(block_net) &
    wait

    mem=$(block_mem)
    bat=$(block_battery)
    vol=$(block_volume)
    media=$(block_media)
    rec=$(block_recorder)
    lang=$(block_lang)
    clock=$(block_clock)

    parts=""
    for block in "$rec" "$media" "$vol" "$net" "$cpu" "$mem" "$bat" "$lang" "$clock"; do
        [ -n "$block" ] && parts="${parts}${parts:+  |  }${block}"
    done

    somebar -c status "$parts"
    sleep "$INTERVAL"
done
